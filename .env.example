DATA_DIR=./manual_txt

# Acesso ao PostgreSQL (usado para montar a URL de conexão)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rag_db

# Opcional: se definir DATABASE_URL, ela substitui host/port/user/password/name
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

RAG_SCHEMA=jawiki
RAG_TABLE=jabot_rag

OLLAMA_MODEL=mxbai-embed-large
OLLAMA_BASE_URL=http://localhost:11434

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Chat web: quantos trechos buscar no RAG por pergunta
CHAT_TOP_K=5
# Opcional: modelo Ollama para gerar resposta (ex: llama3, mistral). Vazio = só mostra trechos
OLLAMA_CHAT_MODEL=llama3

# Cache de perguntas: reutiliza respostas para perguntas muito parecidas (1=ativo, 0=desligado)
CACHE_PERGUNTAS=1
# Tabela de cache (criada automaticamente se não existir). Esquema padrão = mesmo do RAG.
# CACHE_SCHEMA=jawiki
# CACHE_TABLE=jabot_rag_perguntas
# Distância máxima para considerar "mesma" pergunta (0.2 = mais exigente, 0.4 = mais flexível)
# CACHE_THRESHOLD=0.35
# Reutilizar cache só para respostas com avaliação >= N estrelas (1-5). Ex.: 4 = só 4 ou 5 estrelas
# CACHE_MIN_STARS=4
# Dimensão do embedding (mxbai-embed-large = 1024)
# CACHE_EMBEDDING_DIM=1024

# Servidor Flask (chat local)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=1
